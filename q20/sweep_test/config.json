{
  "physical": {
    "parameters": {
      "system": "Hidrogen",
      "num_qubits": 20,
      "distance": "1_0",
      "hamiltonian_source": "Hamiltonians_to_use/pauli_decompositions/index.json",
      "t_initial": 0.0,
      "T": 1.0,
      "tau_range": [0.0, 1.0],
      "schedule": "sinusoidal_sin2"
    }
  },
  "neural": {
    "model": "ProjectedSparseAGPPINN",
    "general": {
      "n_inputs": 1,
      "n_outputs": "agp_top_k",
      "n_hidden": 3,
      "n_neurons": 56,
      "activation": "silu",
      "layer_type": "quadratic"
    }
  },
  "support_sweep": {
    "agp_terms": [576, 768, 1024, 1536, 2048],
    "intermediate_top_k": 2048,
    "residual_top_k": 2048,
    "residual_projection": "largest_generated_commutator_terms",
    "adaptive": {
      "enabled": false,
      "stages": 1,
      "growth_terms_per_stage": 0
    }
  },
  "training": {
    "device": "auto",
    "optimizer": "AdamW",
    "parameters": {
      "epochs": 5000,
      "num_points": 16,
      "lr": 0.0001,
      "random_seed": 11
    },
    "loss": {
      "residual": 1.0,
      "agp_l2": 1e-8
    },
    "export": {
      "path_images": "Images/",
      "path_data": "Models_Data/",
      "top_coefficients": 16,
      "plot_quantity": "d_lambda_dt_times_C_P",
      "format": "pdf"
    }
  },
  "summary": {
    "top_k_overlap": 32,
    "path_images": "Images/",
    "path_data": "Models_Data/",
    "runs_dir": "runs/"
  }
}
