{
  "physical": {
    "parameters": {
      "system": "Hidrogen",
      "num_qubits": 20,
      "distance": "1_0",
      "hamiltonian_source": "Hamiltonians_to_use/pauli_decompositions/index.json",
      "t_initial": 0.0,
      "T": 1.0,
      "tau_range": [0.0, 1.0],
      "schedule": "sinusoidal_sin2"
    }
  },
  "neural": {
    "model": "ProjectedSparseAGPPINN",
    "general": {
      "n_inputs": 1,
      "n_outputs": "agp_top_k",
      "n_hidden": 3,
      "n_neurons": 56,
      "activation": "silu",
      "layer_type": "quadratic"
    }
  },
  "support_sweep": {
    "agp_terms": [1024],
    "intermediate_top_k": 2048,
    "residual_top_k": 2048,
    "residual_projection": "largest_generated_commutator_terms",
    "adaptive": {
      "enabled": false,
      "stages": 1,
      "growth_terms_per_stage": 0
    }
  },
  "holdout_feedback": {
    "base_agp_terms": 1024,
    "holdout_residual_top_k": "auto",
    "iterations": 10,
    "add_residual_terms_per_iteration": 1024,
    "unseen_residual_batches_after_final_iteration": 1,
    "epochs_per_iteration": 1000,
    "lr": 1e-5,
    "device": "mps",
    "min_rms": 0.0,
    "holdout_threshold": 0.10,
    "unseen_threshold": 1.0,
    "output_root": "runs/holdout_feedback"
  },
  "coupled_curriculum": {
    "base_agp_terms": 1024,
    "holdout_residual_top_k": "auto",
    "iterations": 10,
    "add_residual_terms_per_iteration": 256,
    "add_agp_terms_per_iteration": 64,
    "max_agp_terms": 1664,
    "unseen_residual_batches_after_final_iteration": 1,
    "epochs_per_iteration": 1000,
    "lr": 1e-5,
    "device": "mps",
    "min_residual_rms": 0.0,
    "min_agp_score": 0.0,
    "candidate_residual_terms": 512,
    "candidate_hamiltonian_terms": 64,
    "probe_gate_residual_terms": 2048,
    "probe_test_residual_terms": 4096,
    "probe_source_agp_terms": 1664,
    "proposal_multiplier": 4,
    "probe_score_weight": 1.0,
    "probe_max_worsening_factor": 1.05,
    "probe_max_worsening_delta": 0.0,
    "probe_absolute_max_worsening_factor": 1.05,
    "probe_absolute_max_worsening_delta": 0.0,
    "probe_reference_floor": 1e-12,
    "feedback_max_worsening_factor": 1.05,
    "residual_backtracking_factors": [1.0, 0.5, 0.25, 0.0],
    "trust_region_weight": 1e-4,
    "new_agp_warmup_epochs": 100,
    "use_unseen_residuals_for_agp": true,
    "holdout_threshold": 0.10,
    "unseen_threshold": 1.0,
    "output_root": "runs/coupled_curriculum"
  },
  "training": {
    "device": "auto",
    "optimizer": "AdamW",
    "parameters": {
      "epochs": 5000,
      "num_points": 16,
      "lr": 0.0001,
      "random_seed": 11
    },
    "loss": {
      "residual": 1.0,
      "agp_l2": 1e-8
    },
    "export": {
      "path_images": "Images/",
      "path_data": "Models_Data/",
      "top_coefficients": 16,
      "plot_quantity": "d_lambda_dt_times_C_P",
      "format": "pdf"
    }
  },
  "summary": {
    "top_k_overlap": 32,
    "path_images": "Images/",
    "path_data": "Models_Data/",
    "runs_dir": "runs/"
  }
}
