{
  "physical": {
    "parameters": {
      "system": "Hidrogen",
      "num_qubits": 2,
      "distance": "1_0",
      "hamiltonian_source": "Hamiltonians_to_use/pauli_decompositions/index.json",
      "t_initial": 0.0,
      "T": 1.0,
      "tau_range": [0.0, 1.0],
      "schedule": "sinusoidal_sin2"
    }
  },
  "neural": {
    "model": "FullPauliAGPPINN",
    "general": {
      "n_inputs": 1,
      "n_outputs": "4**num_qubits",
      "n_hidden": 3,
      "n_neurons": 56,
      "activation": "silu",
      "layer_type": "quadratic"
    }
  },
  "training": {
    "device": "auto",
    "optimizer": "SOAP",
    "parameters": {
      "epochs": 10,
      "num_points": 32,
      "lr": 0.0001,
      "random_seed": 7
    },
    "loss": {
      "residual": 1.0,
      "agp_l2": 0.0
    },
    "export": {
      "path_images": "Images/",
      "path_data": "Models_Data/",
      "top_coefficients": 12,
      "plot_quantity": "d_lambda_dt_times_C_P",
      "format": "pdf"
    }
  }
}
