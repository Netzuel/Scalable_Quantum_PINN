{
  "physical": {
    "parameters": {
      "system": "TransverseIsingDriverProblem",
      "num_qubits": 15,
      "distance": "1_0",
      "hamiltonian_source": "Hamiltonians_to_use/pauli_decompositions/index.json",
      "t_initial": 0.0,
      "T": 1.0,
      "tau_range": [0.0, 1.0],
      "schedule": "sinusoidal_sin2"
    }
  },
  "neural": {
    "model": "ProjectedSparseAGPPINN",
    "general": {
      "n_inputs": 1,
      "n_outputs": "agp_top_k",
      "n_hidden": 3,
      "n_neurons": 56,
      "activation": "silu",
      "layer_type": "quadratic"
    }
  },
  "default_pipeline": {
    "name": "q15_fixed_k_holdout_feedback_physical_validation",
    "entrypoint": "scripts/agp_holdout_feedback.py",
    "agp_terms": 16384,
    "description": "Fixed K=4**7 AGP support selected from a bounded nested-commutator Krylov pool; ten feedback iterations add hard residual equations without growing AGP outputs."
  },
  "support_sweep": {
    "agp_terms": [16384],
    "output_root": "runs/baselines",
    "intermediate_top_k": 2048,
    "residual_top_k": 2048,
    "residual_projection": "largest_generated_commutator_terms",
    "agp_support_selection": {
      "strategy": "nested_commutator_krylov_pool",
      "max_depth": 8,
      "max_frontier": 65536
    },
    "adaptive": {
      "enabled": false,
      "stages": 1,
      "growth_terms_per_stage": 0
    }
  },
  "holdout_feedback": {
    "base_agp_terms": 16384,
    "holdout_residual_top_k": "auto",
    "iterations": 10,
    "add_residual_terms_per_iteration": 1024,
    "unseen_residual_batches_after_final_iteration": 1,
    "epochs_per_iteration": 1000,
    "lr": 1e-5,
    "device": "auto",
    "min_rms": 0.0,
    "holdout_threshold": 0.10,
    "unseen_threshold": 1.0,
    "baseline_root": "runs/baselines",
    "keep_round_images": false,
    "output_root": "runs/fixed_k_holdout_feedback_v1"
  },
  "training": {
    "device": "auto",
    "optimizer": "AdamW",
    "parameters": {
      "epochs": 5000,
      "num_points": 16,
      "lr": 0.0001,
      "random_seed": 11
    },
    "loss": {
      "residual": 1.0,
      "agp_l2": 1e-8
    },
    "export": {
      "path_images": "Images/",
      "path_data": "Models_Data/",
      "top_coefficients": 32,
      "plot_quantity": "d_lambda_dt_times_C_P",
      "format": "pdf"
    }
  },
  "physical_validation": {
    "entrypoint": "scripts/agp_physical_validation.py",
    "protocols": ["no_cd", "nested_l1", "learned_sparse_agp"],
    "schedule": "sinusoidal_sin2",
    "statevector_qubits": 15,
    "evolution_steps": 96,
    "learned_top_terms": 1024,
    "description": "Post-training q15 statevector diagnostic comparing final observables under no counterdiabatic drive, l=1 nested-commutator CD, and the learned sparse AGP."
  },
  "summary": {
    "top_k_overlap": 32,
    "path_images": "runs/support_sweep_summary/Images/",
    "path_data": "runs/support_sweep_summary/Models_Data/",
    "runs_dir": "runs/"
  }
}
