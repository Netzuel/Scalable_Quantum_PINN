{
  "physical": {
    "parameters": {
      "system": "Hidrogen",
      "num_qubits": 20,
      "distance": "1_0",
      "hamiltonian_source": "Hamiltonians_to_use/pauli_decompositions/index.json",
      "t_initial": 0.0,
      "T": 1.0,
      "tau_range": [0.0, 1.0],
      "schedule": "sinusoidal_sin2"
    }
  },
  "neural": {
    "model": "ProjectedSparseAGPPINN",
    "general": {
      "n_inputs": 1,
      "n_outputs": "agp_top_k",
      "n_hidden": 3,
      "n_neurons": 56,
      "activation": "silu",
      "layer_type": "quadratic"
    }
  },
  "default_pipeline": {
    "name": "fixed_k_holdout_feedback",
    "entrypoint": "scripts/agp_holdout_feedback.py",
    "agp_terms": 16384,
    "description": "Fixed AGP support at 4**7 outputs; curriculum iterations add hard residual equations without swapping or growing AGP outputs."
  },
  "support_sweep": {
    "agp_terms": [16384],
    "output_root": "runs/baselines",
    "intermediate_top_k": 2048,
    "residual_top_k": 2048,
    "residual_projection": "largest_generated_commutator_terms",
    "agp_support_selection": {
      "strategy": "endpoint_commutator"
    },
    "adaptive": {
      "enabled": false,
      "stages": 1,
      "growth_terms_per_stage": 0
    }
  },
  "holdout_feedback": {
    "base_agp_terms": 16384,
    "holdout_residual_top_k": "auto",
    "iterations": 10,
    "add_residual_terms_per_iteration": 1024,
    "unseen_residual_batches_after_final_iteration": 1,
    "epochs_per_iteration": 1000,
    "lr": 1e-5,
    "device": "auto",
    "min_rms": 0.0,
    "holdout_threshold": 0.10,
    "unseen_threshold": 1.0,
    "baseline_root": "runs/baselines",
    "keep_round_images": false,
    "output_root": "runs/fixed_k_holdout_feedback_v2"
  },
  "coupled_curriculum": {
    "role": "diagnostic_not_default",
    "enabled_by_default": false,
    "base_agp_terms": "auto",
    "initial_agp_selector": {
      "endpoint_l2_coverage": 0.995,
      "min_terms": 16384,
      "max_terms": 16384,
      "round_to_multiple": 64
    },
    "support_refinement": {
      "mode": "fixed_budget_swap",
      "active_cap_qubits": 7,
      "active_agp_terms": "auto",
      "exploratory_cap_qubits": 8,
      "exploratory_agp_terms": "auto",
      "candidate_pool_terms": 65536,
      "protected_active_fraction": 0.0
    },
    "holdout_residual_top_k": "auto",
    "iterations": 10,
    "add_residual_terms_per_iteration": 1024,
    "add_agp_terms_per_iteration": 512,
    "max_agp_terms": 16384,
    "unseen_residual_batches_after_final_iteration": 1,
    "epochs_per_iteration": 2000,
    "lr": 5e-6,
    "device": "auto",
    "min_residual_rms": 0.0,
    "min_agp_score": 0.0,
    "candidate_residual_terms": 4096,
    "candidate_hamiltonian_terms": 128,
    "selection_residual_terms": 32768,
    "selection_source_agp_terms": 16384,
    "probe_gate_residual_terms": 16384,
    "probe_watch_residual_terms": 16384,
    "probe_test_residual_terms": 32768,
    "probe_source_agp_terms": 16384,
    "candidate_scoring": "omp",
    "omp_hamiltonian_terms": 64,
    "omp_max_candidates": 2048,
    "omp_tau_points": 16,
    "proposal_multiplier": 16,
    "probe_score_weight": 1.0,
    "require_probe_support_for_agp": true,
    "source_diversity_bonus": 0.5,
    "max_agp_terms_per_order_per_iteration": 32,
    "probe_max_worsening_factor": 1.01,
    "probe_max_worsening_delta": 0.0,
    "probe_absolute_max_worsening_factor": 1.01,
    "probe_absolute_max_worsening_delta": 0.0,
    "probe_reference_floor": 1e-12,
    "feedback_max_worsening_factor": 1.01,
    "probe_improvement_target": 1.0,
    "probe_min_improvement_factor": 0.99,
    "feedback_min_improvement_factor": 1.0,
    "residual_backtracking_factors": [1.0, 0.5, 0.25, 0.0],
    "support_backtracking_schedule": [
      {"residual_factor": 1.0, "agp_factor": 1.0},
      {"residual_factor": 0.5, "agp_factor": 0.5},
      {"residual_factor": 0.25, "agp_factor": 0.25},
      {"residual_factor": 0.0, "agp_factor": 0.25},
      {"residual_factor": 0.25, "agp_factor": 0.0}
    ],
    "trust_region_weight": 1e-2,
    "max_consecutive_no_safe_steps": 3,
    "new_agp_warmup_epochs": 400,
    "randomize_tau_each_epoch": true,
    "oracle": {
      "enabled": true,
      "residual_terms": 2048,
      "hamiltonian_terms": 48,
      "max_agp_terms": 1024
    },
    "use_unseen_residuals_for_agp": true,
    "holdout_threshold": 0.10,
    "unseen_threshold": 1.0,
    "output_root": "runs/diagnostic_fixed_budget_support_refinement_v1"
  },
  "training": {
    "device": "auto",
    "optimizer": "AdamW",
    "parameters": {
      "epochs": 5000,
      "num_points": 16,
      "lr": 0.0001,
      "random_seed": 11
    },
    "loss": {
      "residual": 1.0,
      "agp_l2": 1e-8
    },
    "export": {
      "path_images": "Images/",
      "path_data": "Models_Data/",
      "top_coefficients": 16,
      "plot_quantity": "d_lambda_dt_times_C_P",
      "format": "pdf"
    }
  },
  "summary": {
    "top_k_overlap": 32,
    "path_images": "runs/support_sweep_summary/Images/",
    "path_data": "runs/support_sweep_summary/Models_Data/",
    "runs_dir": "runs/"
  }
}
